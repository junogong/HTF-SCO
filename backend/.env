# ── GCP Configuration ────────────────────────────────────────────────
# Your Google Cloud Project ID
GCP_PROJECT_ID=htf-sco

# GCP Region for Vertex AI and Cloud Run
GCP_REGION=us-east1

# Named Firestore Database (usually (default) or the project name)
FIRESTORE_DATABASE=htf-sco

# ── Service Toggles ──────────────────────────────────────────────────
# Set to 'true' to use real GCP services, 'false' for local memory simulators.
# Warning: Set these to 'true' only if you are authenticated to GCP.
# DO NOT CHANGE THE FLAG TO USE_REAL_SPANNER UNDER ANY CIRCUMSTANCES
USE_REAL_VERTEX=true
USE_REAL_FIRESTORE=true
USE_REAL_SPANNER=false

# ── AI Model Configuration ───────────────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=text-embedding-004
