# ── GCP Configuration ────────────────────────────────────────────────
# Your Google Cloud Project ID
GCP_PROJECT_ID=your-project-id-here

# GCP Region for Vertex AI and Cloud Run
GCP_REGION=us-east1

# Named Firestore Database (usually (default) or the project name)
FIRESTORE_DATABASE=your-db-name-here

# ── Service Toggles ──────────────────────────────────────────────────
# Set to 'true' to use real GCP services, 'false' for local memory simulators.
# Warning: Set these to 'true' only if you are authenticated to GCP.
USE_REAL_VERTEX=true
USE_REAL_FIRESTORE=true
USE_REAL_SPANNER=false

# ── AI Model Configuration ───────────────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=text-embedding-004

# ── Fine-Tuned Classifier ────────────────────────────────────────────
# After running sft_dataset_generator.py and completing the tuning job,
# paste the tuned model endpoint here. Leave empty to use base Flash.
# Example: projects/123456/locations/us-east1/models/abc123
TUNED_CLASSIFIER_MODEL=
